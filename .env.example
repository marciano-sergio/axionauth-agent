# AXIONAuth Agent - Environment Configuration
# Copy this file to .env and fill in your Auth0 credentials

# ============================================================
# Auth0 Configuration
# ============================================================

# Your Auth0 tenant domain (e.g., your-tenant.auth0.com)
AUTH0_DOMAIN=your-tenant.auth0.com

# Application Client ID from Auth0 Dashboard
AUTH0_CLIENT_ID=your_client_id_here

# Application Client Secret from Auth0 Dashboard
AUTH0_CLIENT_SECRET=your_client_secret_here

# Auth0 API Audience for Token Vault
TOKEN_VAULT_AUDIENCE=https://your-tenant.auth0.com/api/v2/

# Auth0 callback URL (must match Auth0 dashboard setting)
AUTH0_CALLBACK_URL=http://localhost:8000/api/auth/callback

# ============================================================
# Application Configuration
# ============================================================

# Port to run the application on
PORT=8000

# Environment: development, staging, production
ENVIRONMENT=development

# Secret key for session encryption (generate a random 32-char string)
SESSION_SECRET=change-me-to-a-random-string

# ============================================================
# Token Vault Settings
# ============================================================

# Default access token TTL in seconds (300 = 5 minutes)
TOKEN_TTL=300

# Maximum active tokens per agent
MAX_TOKENS_PER_AGENT=10

# Enable mTLS verification (true in production)
MTLS_ENABLED=false

# ============================================================
# Logging & Monitoring
# ============================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Enable audit logging
AUDIT_ENABLED=true

# Audit log retention in days
AUDIT_RETENTION_DAYS=90
